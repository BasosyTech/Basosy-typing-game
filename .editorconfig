# السطر ده بيعرف المحرر إن دي الإعدادات الرئيسية للمشروع
root = true

# النجمة معناها إن القواعد دي هتتطبق على كل الملفات
[*]

# ترميز الملف عشان يدعم اللغة العربية وأي لغة تانية بدون مشاكل
charset = utf-8

# توحيد نهايات السطور عشان تشتغل صح على أي نظام تشغيل
end_of_line = lf

# استخدام المسافات بدل التاب
indent_style = space

# حجم المسافة (مسافتين هو التنسيق القياسي في مسارك الحالي)
indent_size = 2

# إضافة سطر فاضي في نهاية كل ملف تلقائياً
insert_final_newline = true

# مسح أي مسافات فارغة ملهاش لازمة في نهاية السطور
trim_trailing_whitespace = true